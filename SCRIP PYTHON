# ==================== FUNGSI UTAMA ====================
class WhatsAppAPI:
    def __init__(self, phone_id, token):
        self.phone_id = phone_id
        self.token = token
        self.base_url = f"https://graph.facebook.com/v18.0/{phone_id}/messages"
        self.headers = {
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json"
        }
        self.session = requests.Session()
        
    def send_text(self, to_number, message):
        """Kirim pesan teks biasa"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "text",
            "text": {"body": message}
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data,
                timeout=10
            )
            
            if response.status_code == 200:
                result = response.json()
                return {
                    "success": True,
                    "message_id": result['messages'][0]['id'],
                    "data": result
                }
            else:
                return {
                    "success": False,
                    "error": response.text,
                    "code": response.status_code
                }
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def send_template(self, to_number, template_name, language="id"):
        """Kirim template message"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "template",
            "template": {
                "name": template_name,
                "language": {"code": language}
            }
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def send_image(self, to_number, image_url, caption=""):
        """Kirim gambar"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "image",
            "image": {
                "link": image_url,
                "caption": caption
            }
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def send_document(self, to_number, doc_url, filename):
        """Kirim dokumen"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "document",
            "document": {
                "link": doc_url,
                "filename": filename
            }
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def send_audio(self, to_number, audio_url):
        """Kirim audio"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "audio",
            "audio": {"link": audio_url}
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def send_location(self, to_number, lat, long, name="", address=""):
        """Kirim lokasi"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "location",
            "location": {
                "latitude": lat,
                "longitude": long,
                "name": name,
                "address": address
            }
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def send_contact(self, to_number, name, phone):
        """Kirim kontak"""
        data = {
            "messaging_product": "whatsapp",
            "to": to_number,
            "type": "contacts",
            "contacts": [
                {
                    "name": {"formatted_name": name},
                    "phones": [{"phone": phone, "type": "CELL"}]
                }
            ]
        }
        
        try:
            response = self.session.post(
                self.base_url,
                headers=self.headers,
                json=data
            )
            return response.status_code == 200
        except:
            return False
    
    def check_phone(self, phone_number):
        """Cek nomor terdaftar atau tidak"""
        if not phone_number.startswith('62'):
            phone_number = '62' + phone_number.lstrip('0')
        
        url = f"https://graph.facebook.com/v18.0/{phone_number}"
        params = {"access_token": self.token}
        
        try:
            response = self.session.get(url, params=params)
            return response.status_code == 200
        except:
            return False

