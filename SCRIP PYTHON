        self.results = {"success": 0, "failed": 0}
        
    def send_message(self, phone, message, method=1):
        """Mengirim pesan WhatsApp via berbagai metode"""
        try:
            headers = {
                'User-Agent': random.choice(USER_AGENTS),
                'Accept': 'text/html,application/xhtml+xml',
                'Accept-Language': 'id-ID,id;q=0.9,en;q=0.8',
                'Connection': 'keep-alive'
            }
            
            encoded_msg = urllib.parse.quote(message)
            
            if method == 1:
                # Metode API langsung
                url = f"{WHATSAPP_API}?phone={phone}&text={encoded_msg}"
            elif method == 2:
                # Metode Web
                url = f"{WHATSAPP_WEB}?phone={phone}&text={encoded_msg}"
            elif method == 3:
                # Metode dengan parameter tambahan
                url = f"https://api.whatsapp.com/send/?phone={phone}&text={encoded_msg}&type=phone_number"
            else:
                url = f"https://wa.me/{phone}?text={encoded_msg}"
            
            response = self.session.get(url, headers=headers, timeout=10, allow_redirects=True)
            
            if response.status_code == 200:
