# ==================== FUNGSI UTILITY ====================
def clear():
    os.system('clear' if os.name == 'posix' else 'cls')

def loading(text="Loading", duration=1):
    chars = "⣾⣽⣻⢿⡿⣟⣯⣷"
    end = time.time() + duration
    i = 0
    while time.time() < end:
        sys.stdout.write(f"\r{Colors.CYAN}[{chars[i%8]}] {text}{Colors.END}")
        sys.stdout.flush()
        time.sleep(0.1)
        i += 1
    print()

def success(text):
    print(f"{Colors.GREEN}[✓] {text}{Colors.END}")

def error(text):
    print(f"{Colors.RED}[✗] {text}{Colors.END}")

def info(text):
    print(f"{Colors.BLUE}[ℹ] {text}{Colors.END}")

def warning(text):
    print(f"{Colors.YELLOW}[⚠] {text}{Colors.END}")

def progress(current, total, text=""):
    percent = (current/total)*100
    bar = '█' * int(percent/2) + '░' * (50 - int(percent/2))
    sys.stdout.write(f"\r{Colors.CYAN}[{bar}] {percent:.1f}% {text}{Colors.END}")
    sys.stdout.flush()

